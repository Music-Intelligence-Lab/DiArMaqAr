    "id": "49",
    "idName": "jins_awj_ara_(al-hilu)",
    "name": "jins awj ʾārāʾ (al-Ḥilū)",
    "noteNames": [
      "kawasht",
      "rāst",
      "kurdī",
      "būselīk/ʿushshāq"
