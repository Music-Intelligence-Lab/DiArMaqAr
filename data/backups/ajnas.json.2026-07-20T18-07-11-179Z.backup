  {
    "id": "17",
    "idName": "jins_hijaz_kar_kurd",
    "name": "jins ḥijāz kār kurd",
    "noteNames": [
      "rāst",
      "zīrgūleh",
      "kurdī",
      "chahārgāh"
    ],
    "commentsEnglish": "Jins kurd on rast (C/Do) often has slightly different intervals to a standard transposition of jins kurd from dūgāh (D/Re) onto rāst. In many tuning systems it doesn't even transpose. Named jins ḥijāz kār kurd because it is the primary jins of maqām ḥijāz kār kurd.",
    "commentsArabic": "",
    "sourcePageReferences": [],
    "version": "2026-07-20T17:56:52.415Z"
  },
