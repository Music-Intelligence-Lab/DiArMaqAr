  {
    "id": "66",
    "idName": "maqam_ushshaq",
    "name": "maqām ʿushshāq",
    "ascendingNoteNames": [
      "dūgāh",
      "segāh",
      "chahārgāh",
      "nawā",
      "ḥusaynī",
      "ʿajam",
      "kurdān"
    ],
    "descendingNoteNames": [
      "kurdān",
      "ʿajam",
      "ḥusaynī",
      "nawā",
      "chahārgāh",
      "segāh",
      "dūgāh"
    ],
    "primaryJinsDegree": null,
    "secondaryJinsDegree": null,
    "tertiaryJinsDegree": null,
    "ghammaz": null,
    "suyur": [
      {
        "id": "sayralshawwa_1946",
        "creatorEnglish": "",
        "creatorArabic": "",
        "sourceId": "alshawwa_1946",
        "page": "60",
        "commentsEnglish": "Its scale does not differ from maqām bayyāt; the difference is in the sayr — the reverse of bayyāt: it begins from rāst to nawā ascending and descending, then from nawā to muḥayyar, then returns descending to the qarārs and ends on dūgāh. This ʿushshāq is distinct from the ʿushshāq used in Egypt.",
        "commentsArabic": "هذا المقـام لايختلف تركيب درجاته عن درجات سلم مقام البياتى إلا أن الاختلاف فى السـير إذ أن مقام البيــاتى يبدأ من صوت الجهاركاه أو النواه صعوداً إلى الحسينى والعجم والـكردان والمحير صعوداً وهبوطاً مراراً ثم يعود من بردة ، أى من صوت ، النواه إلى الجهاركاه والثيه كاه والدوكاه والراست الخ وينتهى قراره على صوت الدوكاه : وأما العشاق فبالعكس إذ أنه يبدأ من صوت الراست إلى النواه صعوداً وهبوطاً ثم من النواه إلى المحير ثم يعود هبوطاً إلى القرارات وينتهى قراره على صوت الدوكاه وهذا هو مقـام العشاق خلاف العشـاق المستعمل فى مصر .",
        "stops": [
          {
            "type": "note",
            "value": "rāst"
          },
          {
            "type": "direction",
            "value": "ascending"
          },
          {
            "type": "note",
            "value": "nawā"
          },
          {
            "type": "direction",
            "value": "descending"
          },
          {
            "type": "direction",
            "value": "ascending"
          },
          {
            "type": "note",
            "value": "muḥayyar"
          },
          {
            "type": "direction",
            "value": "descending"
          },
          {
            "type": "note",
            "value": "dūgāh"
          }
        ],
        "version": "2026-07-19T19:12:36.330Z"
      }
    ],
