      "nawā"
    ],
    "suyur": [
      {
        "id": "sayralshawwa_1946",
        "creatorEnglish": "al-Shawwā, Sāmī",
        "creatorArabic": "",
        "sourceId": "alshawwa_1946",
        "page": "22",
        "commentsEnglish": "Start with jins bayyāt on dūgāh, ending on 'irāq. Then ascend and descend ending on note 'ushayrān. Repeat jins bayyāt on dūgāh, and descend to end on the qarār which is yegāh. This maqām name corresponds with a Persian Gushe also called Majlis Afrooz in the Dastgah Mahūr and Dastgāh Shūr. In Mahūr it bears no melodic or intervallic resemblance, but in Shūr the jins bayyāt is prominent.",
        "commentsArabic": "هذا المقام يستهل بعمل مقام عراق مع اظهار الجنس الاول للبياتى على صوت الدوكاه وينتهى أولا على صوت العراق ثم يعود صعوداً وينتهى هبوطاً على صوت العشيران ثانياً يكرر العمل على صوت الدوكاه بعمل مقام البياتى ويصير الهبوط إلى القرار وقراره هو صوت اليك كاه .",
        "stops": [
          {
            "type": "jins",
            "value": "2",
            "startingNote": "dūgāh",
            "direction": "none"
          },
          {
            "type": "note",
            "value": "ʿirāq"
          },
          {
            "type": "direction",
            "value": "ascending",
            "startingNote": "ʿirāq",
            "direction": "ascending"
          },
          {
            "type": "direction",
            "value": "descending"
          },
          {
            "type": "note",
            "value": "ʿushayrān",
            "startingNote": "dūgāh",
            "direction": "none"
          },
          {
            "type": "jins",
            "value": "2",
            "startingNote": "dūgāh",
            "direction": ""
          },
          {
            "type": "direction",
            "value": "descending"
          },
          {
            "type": "note",
            "value": "yegāh"
          }
        ],
        "version": "2026-07-19T19:12:36.330Z"
      }
    ],
