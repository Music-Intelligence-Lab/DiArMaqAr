          },
          {
            "type": "direction",
            "value": "descending"
          },
          {
            "type": "note",
            "value": "dūgāh"
          }
        ],
        "version": "2026-07-19T19:12:36.330Z"
      }
    ],
    "commentsEnglish": "Turkish karcığar; book spelling قرجهار.",
    "commentsArabic": "",
